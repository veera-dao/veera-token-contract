{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "./hardhat.config.ts",
    "./layerzero.config.ts",
    "./config/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "integration-tests"
  ]
}
