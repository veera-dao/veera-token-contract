# .env.example

# ==============================================================================
# INFRASTRUCTURE
# ==============================================================================

# RPC Endpoint for Base Mainnet
# Recommended: Alchemy, Ankr, Infura, or QuickNode (Public RPCs may rate limit during deployment)
BASE_RPC_URL=https://rpc.ankr.com/base_sepolia/<api_key>

# Basescan API Key
# Required for automatic contract verification during deployment.
# Get one here: https://basescan.org/myapikey
ETHERSCAN_API_KEY=ABC123ABC123ABC123ABC123ABC123

# Flag passed to foundry indicating the type of hardware wallet being used for deployment.
# Either --ledger or --trezor
HARDWARE=--ledger

# The address of the hardware wallet used for deployment.
HARDWARE_WALLET_ADDRESS=0x000...

# ==============================================================================
# DEPLOYMENT SIGNER
# ==============================================================================
# NOTE: This project uses Hardware Wallets (Ledger/Trezor) for production deployment.
# Private keys are NOT stored in this file for mainnet operations.
#
# If running CI/CD or Testnet deployments without a hardware wallet, you may 
# uncomment the line below, but NEVER commit a real private key to Git.
# PRIVATE_KEY=0x...

# ==============================================================================
# HARDCODED CONFIGURATION (For Reference)
# ==============================================================================
# These values are hardcoded in script/HelperConfig.s.sol.
# To change them, modify the Solidity script directly.
#
# Token Name:    "Veera Token"
# Token Symbol:  "VEERA"
# Initial Supply: 1,000,000,000 (10^18 precision)
# Initial Admin:  0x0000...
