# .env.example

# ==============================================================================
# INFRASTRUCTURE
# ==============================================================================

# RPC Endpoints for Networks
BASE_RPC_URL=https://rpc.ankr.com/base/<api_key>
BSC_RPC_URL=https://rpc.ankr.com/bsc/<api_key>
BASE_SEPOLIA_RPC_URL=https://rpc.ankr.com/base_sepolia/<api_key>
BSC_TESTNET_RPC_URL=https://rpc.ankr.com/bsc_testnet_chapel/<api_key>

# Basescan / Etherscan API Key
# Required for automatic contract verification.
ETHERSCAN_API_KEY=ABC123ABC123ABC123ABC123ABC123

# LayerZero pathway configuration signer (delegate/owner)
# For mainnet, keep blank and use --dry-run to generate calldata for Gnosis Safe
LZ_CONFIG_PRIVATE_KEY=0x...

# Flag passed to foundry indicating the type of hardware wallet being used for deployment.
# Either --ledger or --trezor
HARDWARE=--ledger

# The address used for deployment.
DEPLOYER_ADDRESS=0x000...

# Deployment manifest path relative to project root.
# E.g. deploy_manifest.testnet.json, deploy_manifest.mainnet.json, or deploy_manifest.local.json
DEPLOY_MANIFEST_PATH=deploy_manifest.testnet.json

# ==============================================================================
# DEPLOYMENT SIGNER
# ==============================================================================
# NOTE: This project uses Hardware Wallets (Ledger/Trezor) for production deployment.
# Private keys are NOT stored in this file for mainnet operations.
#
# If running CI/CD or Testnet deployments without a hardware wallet, you may 
# uncomment the line below, but NEVER commit a real private key to Git.
# DEPLOYER_PRIVATE_KEY=0x...

# ==============================================================================
# HARDCODED CONFIGURATION (For Reference)
# ==============================================================================
# These values are hardcoded in script/HelperConfig.s.sol.
# To change them, modify the Solidity script directly.
#
# Token Name:    "Veera Token"
# Token Symbol:  "VEERA"
# Initial Supply: 1,000,000,000 (10^18 precision)
# Initial Admin:  0x0000...
