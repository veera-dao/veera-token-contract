# .env.example

# ==============================================================================
# INFRASTRUCTURE
# ==============================================================================

# RPC Endpoint for the target network.
# Set this to the RPC URL for the chain you are deploying to.
# Recommended providers: Alchemy, Ankr, Infura, or QuickNode (Public RPCs may rate limit during deployment)
#
# Base Mainnet:  https://mainnet.base.org
# Base Sepolia:  https://sepolia.base.org
# BSC Mainnet:   https://bsc-dataseed.binance.org
# BSC Testnet:   https://data-seed-prebsc-1-s1.binance.org:8545
BASE_RPC_URL=https://rpc.ankr.com/base_sepolia/<api_key>

# Block Explorer API Key
# Required for automatic contract verification during deployment.
# Use the API key from Etherscan

# Flag passed to foundry indicating the type of hardware wallet being used for deployment.
# Either --ledger or --trezor
HARDWARE=--ledger

# The address used for deployment.
DEPLOYER_ADDRESS=0x000...

# ==============================================================================
# DEPLOYMENT SIGNER
# ==============================================================================
# NOTE: This project uses Hardware Wallets (Ledger/Trezor) for production deployment.
# Private keys are NOT stored in this file for mainnet operations.
#
# If running CI/CD or Testnet deployments without a hardware wallet, you may 
# uncomment the line below, but NEVER commit a real private key to Git.
# PRIVATE_KEY=0x...

# ==============================================================================
# HARDCODED CONFIGURATION (For Reference)
# ==============================================================================
# These values are hardcoded in script/HelperConfig.s.sol.
# To change them, modify the Solidity script directly.
#
# Token Name:    "Veera Token"
# Token Symbol:  "VEERA"
# Initial Supply: 1,000,000,000 on Base / 0 on BSC (bridged token)
# Max Supply:     1,000,000,000 (10^18 precision)
# Initial Admin:  Chain-specific (see HelperConfig.s.sol)
